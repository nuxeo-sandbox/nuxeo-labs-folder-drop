<!-- See documentation at http://doc.nuxeo.com/x/HgIz -->
<package type="addon" name="nuxeo-labs-folder-drop" version="@VERSION@">
  <title>Nuxeo Labs Folder Drop</title>
  <description>
    <p>Drag-and-drop folder import for Nuxeo Web UI. Drop a folder from your desktop
    and its content is imported into Nuxeo preserving the folder hierarchy.
    Supports an optional callback automation chain to customize the document types created.</p>
  </description>
  <vendor>Hyland</vendor>
  <installer restart="true" />
  <uninstaller restart="true" />
  <nuxeo-validation>none</nuxeo-validation>
  <production-state>testing</production-state>
  <supported>false</supported>
  <target-platform>
    <name>lts</name>
    <version>[@NUXEO_TARGET_VERSION@,)</version>
  </target-platform>
  <dependencies>
    <package>nuxeo-web-ui</package>
  </dependencies>
  <license>Apache License, Version 2.0</license>
  <license-url>http://www.apache.org/licenses/LICENSE-2.0</license-url>
  <visibility>DEV</visibility>
</package>
