<?xml version="1.0"?>
<component name="nuxeo.labs.folderdrop.contrib">

  <documentation>
    Deploys the Web UI resources for the Folder Drop plugin.
    @since 2025.1
  </documentation>

  <!-- Register the Web UI entry-point HTML as a web resource -->
  <extension target="org.nuxeo.ecm.platform.WebResources" point="resources">
    <resource name="nuxeo-labs-folder-drop-contrib.html" type="import">
      <uri>/ui/nuxeo-labs-folder-drop/nuxeo-labs-folder-drop-contrib.html</uri>
    </resource>
  </extension>

  <!-- Append our resource to the web-ui bundle so it gets loaded -->
  <extension target="org.nuxeo.ecm.platform.WebResources" point="bundles">
    <bundle name="web-ui">
      <resources append="true">
        <resource>nuxeo-labs-folder-drop-contrib.html</resource>
      </resources>
    </bundle>
  </extension>

</component>
